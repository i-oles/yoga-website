{{ define "pass" }}
<div class="pass-visual"
    style="padding-top:15px; padding-bottom:15px; text-align:center;">

    <table style="margin:0 auto; border-collapse:collapse;">
        <tr>

            {{ range .PassItemsView }}
            <td
                style="width:30px; text-align:center; padding:0 5px; vertical-align:top;">

                {{ if eq .Status 1 }}
                <!-- PAST -->
                <div
                    style="width:16px; height:16px; margin:0 auto; border:2px solid #7cb342; border-radius:50%; background-color:#7cb342; line-height:16px; text-align:center;">
                    <span style="color:white; font-size:9px; font-weight:bold;">✓</span>
                </div>

                {{ else }}
                <!-- FUTURE + BLANK -->
                <div
                    style="width:16px; height:16px; margin:0 auto; border:2px solid #9e9e9e; border-radius:50%;">
                </div>
                {{ end }}

                <div
                    style="margin-top:6px; min-height:12px; font-size:9px; color:#d0d0d0; line-height:1.1; white-space:nowrap;">

                    {{ if and (ne .Status 0) .ClassStartDate }}
                        {{ .ClassStartDate }}
                    {{ else }}
                        &nbsp;
                    {{ end }}

                </div>

            </td>
            {{ end }}

        </tr>
    </table>

</div>
{{ end }}
